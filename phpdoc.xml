<?xml version="1.0" encoding="utf-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/3.0/phpdoc.xsd"
>
    <title>Mediatekformation - Documentation technique</title>
    <paths>
        <!-- Dossier de sortie de la documentation générée -->
        <output>docs/</output>
        <!-- Dossier de cache phpDocumentor -->
        <cache>.phpdoc/cache</cache>
    </paths>
    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>src/Controller</path>
                <path>src/Entity</path>
                <path>src/Form</path>
                <path>src/Repository</path>
            </source>
            <!-- Exclut le code auto-généré par Symfony -->
            <ignore hidden="true">
                <path>src/Kernel.php</path>
            </ignore>
            <output>api</output>
        </api>
    </version>
</phpdocumentor>