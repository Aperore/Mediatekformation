{% extends "basefront.html.twig" %}
{% block body %}
<div class="container mt-4">

    {# MODIFICATION : Titre dynamique selon ajout ou modification
       formation.id est null pour une nouvelle formation (objet vide),
       non null pour une formation existante. #}
    {% if formation.id %}
        <h2 class="text-info mb-3">Modifier : {{ formation.title }}</h2>
    {% else %}
        <h2 class="text-info mb-3">Ajouter une formation</h2>
    {% endif %}

    {# Affichage des erreurs de validation du formulaire #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('formations') }}" class="btn btn-secondary">Annuler</a>
        </div>
    {{ form_end(form) }}

</div>
{% endblock %}
