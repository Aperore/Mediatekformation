{# empty Twig template #}
{% extends "basefront.html.twig" %}
{% block body %}
<div class="container mt-4">

    {# AJOUT : titre dynamique selon le contexte.
       playlist.id vaut null pour un objet non encore persisté (ajout),
       et un entier pour une playlist existante (modification). #}
    {% if playlist.id %}
        <h2 class="text-info mb-3">Modifier : {{ playlist.name }}</h2>
    {% else %}
        <h2 class="text-info mb-3">Ajouter une playlist</h2>
    {% endif %}

    {# AJOUT : messages flash (confirmation de l'action précédente) #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# AJOUT : formulaire Symfony.
       form_start  → génère <form method="POST" ...>
       form_widget → génère tous les champs déclarés dans PlaylistType
       form_end    → ferme </form> et ajoute le token CSRF caché automatiquement #}
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('playlists') }}" class="btn btn-secondary">Annuler</a>
        </div>
    {{ form_end(form) }}

    {# AJOUT : section formations en lecture seule, visible uniquement en mode modification.
       "formations" n'est passé par le contrôleur que dans modifier(), pas dans new().
       "is defined" évite une erreur Twig si la variable est absente. #}
    {% if formations is defined %}
        <hr class="mt-4">
        <h4 class="mt-3">Formations de cette playlist</h4>

        {% if formations|length > 0 %}
            <p class="text-muted">
                <small>
                    Lecture seule. Pour changer la playlist d'une formation,
                    utilisez le formulaire de modification de la formation concernée.
                </small>
            </p>
            <ul class="list-group mt-2">
                {% for formation in formations %}
                    {# AJOUT : chaque formation est affichée avec sa date.
                       Pas de bouton ni de champ de formulaire : lecture seule uniquement. #}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        {{ formation.title }}
                        <span class="text-muted small">{{ formation.publishedatstring }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            {# AJOUT : message explicite si la playlist n'a encore aucune formation #}
            <p class="text-muted">Aucune formation dans cette playlist.</p>
        {% endif %}
    {% endif %}

</div>
{% endblock %}