{% extends "base.html.twig" %}
{% block title %}Administration{% endblock %}
{% block stylesheets %}{% endblock %}

{% block top %}
<div class="container">
    {# Identique au front office #}
    <div class="text-left">
        <img src="{{ app.request.getBasePath()~'/banniere.jpg' }}">
    </div>

    {# Barre de navigation back office #}
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('admin') }}">Accueil admin</a>
                </li>
                <li class="nav-item">
                    {# lien vers la gestion des formations (back office) #}
                    <a class="nav-link" href="{{ path('formations') }}">Formations</a>
                </li>
                <li class="nav-item">
                    {# lien vers la gestion des playlists (back office) #}
                    <a class="nav-link" href="{{ path('playlists') }}">Playlists</a>
                </li>
                <li class="nav-item">
                    {# lien vers la gestion des catégories (back office) #}
                    <a class="nav-link" href="{{ path('categories') }}">Catégories</a>
                </li>
            </ul>

            {# affichage du login connecté + lien de déconnexion.
               app.user non null uniquement si l'utilisateur est authentifié.
               app.user.userIdentifier retourne le login (ici "admin"). #}
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <span class="nav-link text-muted">
                        {{ app.user.userIdentifier }}
                    </span>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-danger" href="{{ path('admin.logout') }}">
                        Se déconnecter
                    </a>
                </li>
            </ul>
        </div>
    </nav>
</div>
{% endblock %}

{% block body %}{% endblock %}

{% block footer %}
<div class="container text-center">
    <footer>
        <hr>
        <p><small><i>Administration Mediatek Formation</i></small></p>
    </footer>
</div>
{% endblock %}

{% block javascripts %}{% endblock %}